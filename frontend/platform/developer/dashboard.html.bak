              <img loading="lazy"
                src="/images/wallet-02.svg"
                alt="Wallet"
                class="mobile-burger-menu__nav-icon"
              />
            </div>
            <span class="mobile-burger-menu__nav-text">Wallet</span></a
          ><!-- Portfolio -->
          <a href="/portfolio" class="mobile-burger-menu__nav-item"
            ><div class="mobile-burger-menu__nav-icon-wrapper">
              <img loading="lazy"
                src="/images/line-chart-up-02.svg"
                alt="Portfolio"
                class="mobile-burger-menu__nav-icon"
              />
            </div>
            <span class="mobile-burger-menu__nav-text">Portfolio</span> </a
          ><!-- Rewards -->
          <div
            class="mobile-burger-menu__nav-item mobile-burger-menu__nav-item--disabled"
          >
            <div class="mobile-burger-menu__nav-icon-wrapper">
              <img loading="lazy"
                src="/images/star-01.svg"
                alt="Rewards"
