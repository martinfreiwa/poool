              />
            </div>
            <span class="mobile-burger-menu__nav-text">Rewards</span>
            <span class="mobile-burger-menu__nav-badge soon-badge">Soon</span>
          </div>
          <!-- Cart -->
          <a href="/cart" class="mobile-burger-menu__nav-item"
            ><div class="mobile-burger-menu__nav-icon-wrapper">
              <img loading="lazy"
                src="/images/shopping-cart-01.svg"
                alt="Cart"
                class="mobile-burger-menu__nav-icon"
              />
            </div>
            <span class="mobile-burger-menu__nav-text">Cart</span></a
          ><!-- Leaderboard -->
          <div
            class="mobile-burger-menu__nav-item mobile-burger-menu__nav-item--disabled"
          >
            <div class="mobile-burger-menu__nav-icon-wrapper">
              <img loading="lazy"
                src="/images/award-05.svg"
                alt="Leaderboard"
                class="mobile-burger-menu__nav-icon"
              />
            </div>
            <span class="mobile-burger-menu__nav-text">Leaderboard</span>
            <span class="mobile-burger-menu__nav-badge soon-badge">Soon</span>
          </div>
          <!-- Settings -->
          <a href="/settings" class="mobile-burger-menu__nav-item"
            ><div class="mobile-burger-menu__nav-icon-wrapper">
              <img loading="lazy"
                src="/images/settings-01.svg"
                alt="Settings"
                class="mobile-burger-menu__nav-icon"
              />
            </div>
            <span class="mobile-burger-menu__nav-text">Settings</span></a
          ><!-- Support -->
          <a href="/support" class="mobile-burger-menu__nav-item"
            ><div class="mobile-burger-menu__nav-icon-wrapper">
              <img loading="lazy"
                src="/static/images/message-chat-circle grey.svg"
                alt="Support"
                class="mobile-burger-menu__nav-icon"
              />
            </div>
            <span class="mobile-burger-menu__nav-text">Support</span>
            <div class="mobile-burger-menu__support-badge">
              <span class="mobile-burger-menu__support-dot"></span>
              <span class="mobile-burger-menu__support-text">Online</span>
            </div></a
          >
        </div>
        <!-- Footer -->
        <div class="mobile-burger-menu__footer">
          <!-- Featured Card - Only show for investor profile -->
          <div class="mobile-burger-menu__featured-card">
            <button
              class="mobile-burger-menu__featured-close"
