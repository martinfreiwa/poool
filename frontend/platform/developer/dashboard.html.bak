            </svg>
          </div>
          <!-- Marketplace Children -->
          <div
            id="mobile-nav-children-marketplace"
            class="mobile-burger-menu__nav-children mobile-burger-menu__nav-children--collapsed"
          >
            <a href="/marketplace" class="mobile-burger-menu__nav-child"
