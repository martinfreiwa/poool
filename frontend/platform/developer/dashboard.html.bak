            <!-- Profile Dropdown JavaScript -->
            <script>
              // Profile Dropdown Functions - Global scope
              window.toggleProfileDropdown = function () {
                const dropdown = document.getElementById(
                  "profile-dropdown-menu",
                );
                const button = document.getElementById(
                  "account-menu-button-inner",
                );

                if (!dropdown) {
                  return;
                }

                // SAFARI FIX: Move to body and restore proper styling

                // Move to body to escape stacking context
                if (dropdown.parentNode !== document.body) {
                  document.body.appendChild(dropdown);
                }

                // Apply proper dropdown styles (restore original design)
                dropdown.style.display = "flex";
                dropdown.style.position = "fixed";
                dropdown.style.left = "248px"; // Original position
                dropdown.style.bottom = "20px"; // Original position
                dropdown.style.width = "264px"; // Original width
                dropdown.style.height = "auto"; // Original height
                dropdown.style.background = ""; // Clear test background
                dropdown.style.border = ""; // Clear test border
                dropdown.style.zIndex = "99999"; // High z-index for Safari

                // Restore original CSS classes
                dropdown.className = "profile-dropdown-menu";

                if (button) button.classList.add("active");

                // Add click outside listener
                setTimeout(() => {
                  document.addEventListener(
                    "click",
                    window.closeDropdownOnClickOutside,
                  );
                }, 100);
              };

              window.closeProfileDropdown = function () {
                const dropdown = document.getElementById(
                  "profile-dropdown-menu",
                );
                const button = document.getElementById(
                  "account-menu-button-inner",
                );

                if (dropdown) dropdown.style.display = "none";
                if (button) button.classList.remove("active");

                // Remove click outside listener
                document.removeEventListener(
                  "click",
                  window.closeDropdownOnClickOutside,
                );
              };

              window.closeDropdownOnClickOutside = function (event) {
                const dropdown = document.getElementById(
                  "profile-dropdown-menu",
                );
                const accountCard = document.getElementById("nav-account-card");

                if (
                  accountCard &&
                  !accountCard.contains(event.target) &&
                  dropdown &&
                  !dropdown.contains(event.target)
                ) {
                  window.closeProfileDropdown();
                }
              };
            </script>
          </aside></template
        ><!-- Profile Dropdown Functions - Global scope for all sidebars -->
        <script>
          // GLOBAL Profile Dropdown Functions (persistent across sidebar changes)
          window.toggleProfileDropdown = function () {
            const dropdown = document.getElementById("profile-dropdown-menu");
            const button = document.getElementById("account-menu-button-inner");

            if (!dropdown) {
              return;
            }

            if (
              dropdown.style.display === "none" ||
              dropdown.style.display === ""
            ) {
              // SAFARI FIX: Move to body and restore proper styling

              // Move to body to escape stacking context
              if (dropdown.parentNode !== document.body) {
                document.body.appendChild(dropdown);
              }

              // Apply proper dropdown styles (restore original design)
              dropdown.style.display = "flex";
              dropdown.style.position = "fixed";
              dropdown.style.left = "248px"; // Original position
              dropdown.style.bottom = "20px"; // Original position
              dropdown.style.width = "264px"; // Original width
              dropdown.style.height = "auto"; // Original height
              dropdown.style.background = ""; // Clear test background
              dropdown.style.border = ""; // Clear test border
              dropdown.style.zIndex = "99999"; // High z-index for Safari

              // Restore original CSS classes
              dropdown.className = "profile-dropdown-menu";

              if (button) button.classList.add("active");

              // Add click outside listener
              setTimeout(() => {
                document.addEventListener(
                  "click",
                  window.closeDropdownOnClickOutside,
                );
              }, 100);
            } else {
              window.closeProfileDropdown();
            }
          };

          window.closeProfileDropdown = function () {
            const dropdown = document.getElementById("profile-dropdown-menu");
            const button = document.getElementById("account-menu-button-inner");

            if (dropdown) dropdown.style.display = "none";
            if (button) button.classList.remove("active");

            // Remove click outside listener
            document.removeEventListener(
              "click",
              window.closeDropdownOnClickOutside,
            );
          };

          window.closeDropdownOnClickOutside = function (event) {
            const dropdown = document.getElementById("profile-dropdown-menu");
            const accountCard = document.getElementById("nav-account-card");

            if (
              accountCard &&
              !accountCard.contains(event.target) &&
              dropdown &&
              !dropdown.contains(event.target)
            ) {
              window.closeProfileDropdown();
            }
          };

          // Profile switching functionality for wrapper - matches other layouts
          window.switchProfile = function (profileType) {
            localStorage.setItem("selectedProfile", profileType);

            // Close dropdown first
            window.closeProfileDropdown();

            // Use same redirect logic as other pages
            const currentPath = window.location.pathname;

            if (profileType === "developer") {
              // Always redirect to developer dashboard when switching to developer profile
              window.location.href = "/developer/dashboard";
            } else {
              // Switch to investor flow
              if (currentPath.startsWith("/developer/")) {
                // Currently in developer path, redirect to investor marketplace
                window.location.href = "/marketplace";
              } else {
                // Already in investor flow, redirect to marketplace
                window.location.href = "/marketplace";
              }
            }
          };

          // Add click handlers for account switching
          document.addEventListener("DOMContentLoaded", function () {
            document.body.addEventListener("click", function (e) {
              const accountItem = e.target.closest(
                ".profile-menu-item.account-item",
              );

              if (accountItem) {
                e.stopPropagation();

                // Determine profile type from account item
                const isSelected = accountItem.classList.contains("selected");
                if (!isSelected) {
                  const accountId = accountItem.id;
                  const profileType = accountId.includes("developer")
                    ? "developer"
                    : "investor";

                  // Remove selected from all items
                  document
                    .querySelectorAll(".profile-menu-item.account-item")
                    .forEach((item) => {
                      item.classList.remove("selected");
                      const checkbox = item.querySelector(".profile-checkbox");
                      if (checkbox) checkbox.classList.remove("selected");
                    });

                  // Add selected to clicked item
                  accountItem.classList.add("selected");
                  const checkbox =
                    accountItem.querySelector(".profile-checkbox");
                  if (checkbox) checkbox.classList.add("selected");

                  // Switch profile
                  window.switchProfile(profileType);
                }
              }
            });
          });

          // GLOBAL Navigation Expand/Collapse Functions
          window.toggleNavExpand = function (itemId) {
            const childrenContainer = document.getElementById(
              "nav-children-" + itemId,
            );
            const chevronIcon = document.getElementById(
              "nav-chevron-" + itemId,
            );

            if (!childrenContainer || !chevronIcon) return;

            // Check if currently collapsed
            const isCollapsed = childrenContainer.classList.contains(
              "sidebar__nav-children--collapsed",
            );

            // Toggle based on current state
            if (isCollapsed) {
              // Save current transition style
              const originalTransition = childrenContainer.style.transition;

              // Temporarily disable transitions for accurate measurement
              // This prevents padding transition from affecting scrollHeight calculation
              childrenContainer.style.transition = "none";

              // Remove collapsed class (padding immediately becomes 4px instead of transitioning)
              childrenContainer.classList.remove(
                "sidebar__nav-children--collapsed",
              );

              // Force reflow to apply the padding change immediately
              childrenContainer.offsetHeight;

              // Measure scrollHeight (now includes full padding, not mid-transition)
              const height = childrenContainer.scrollHeight;

              // Set height to 0 as starting point for animation
              childrenContainer.style.height = "0px";

              // Force another reflow
              childrenContainer.offsetHeight;

              // Restore transitions
              childrenContainer.style.transition = originalTransition || "";

              // In next frame, set height to target (will animate smoothly from 0 to full height)
              requestAnimationFrame(function () {
                childrenContainer.style.height = height + "px";
              });

              chevronIcon.classList.add("sidebar__nav-chevron--expanded");
              localStorage.setItem("nav-expanded-" + itemId, "true");
            } else {
              // Collapsing: set height to 0, then add collapsed class
              childrenContainer.style.height = "0px";
              childrenContainer.classList.add(
                "sidebar__nav-children--collapsed",
              );
              chevronIcon.classList.remove("sidebar__nav-chevron--expanded");
              localStorage.setItem("nav-expanded-" + itemId, "false");
            }
          };

          // Event delegation for parent nav items
          document.addEventListener("DOMContentLoaded", function () {
            // Get sidebar element to add no-transition class
            const sidebar = document.getElementById("sidebar-navigation");

            // Add no-transition class to prevent animation flash during setup
            if (sidebar) {
              sidebar.classList.add("sidebar--no-transition");
            }

            // Use double requestAnimationFrame to ensure DOM is fully rendered
            // before calculating heights (fixes clipping issue)
            requestAnimationFrame(function () {
              requestAnimationFrame(function () {
                // Restore expanded state from localStorage first
                const parentItems = document.querySelectorAll(
                  ".sidebar__nav-item--parent",
                );
                parentItems.forEach(function (parentItem) {
                  const itemId = parentItem.getAttribute("data-item-id");
                  if (itemId) {
                    const savedState = localStorage.getItem(
                      "nav-expanded-" + itemId,
                    );
                    const childrenContainer = document.getElementById(
                      "nav-children-" + itemId,
                    );
                    const chevronIcon = document.getElementById(
                      "nav-chevron-" + itemId,
                    );

                    if (childrenContainer && chevronIcon) {
                      const isCurrentlyCollapsed =
                        childrenContainer.classList.contains(
                          "sidebar__nav-children--collapsed",
                        );
                      const shouldBeExpanded = savedState === "true";

                      if (shouldBeExpanded && isCurrentlyCollapsed) {
                        childrenContainer.classList.remove(
                          "sidebar__nav-children--collapsed",
                        );
                        chevronIcon.classList.add(
                          "sidebar__nav-chevron--expanded",
                        );
                      } else if (!shouldBeExpanded && !isCurrentlyCollapsed) {
                        childrenContainer.classList.add(
                          "sidebar__nav-children--collapsed",
                        );
                        chevronIcon.classList.remove(
                          "sidebar__nav-chevron--expanded",
                        );
                      }
                    }
                  }
                });

                // Set initial heights for all nav children after state is restored
                document
                  .querySelectorAll(".sidebar__nav-children")
                  .forEach(function (container) {
                    if (
                      !container.classList.contains(
                        "sidebar__nav-children--collapsed",
                      )
                    ) {
                      const height = container.scrollHeight;
                      container.style.height = height + "px";
                    }
                  });

                // Remove no-transition class to enable smooth animations from now on
                if (sidebar) {
                  sidebar.classList.remove("sidebar--no-transition");
                }
              });
            });

            // Handle clicks on parent nav items
            document.addEventListener("click", function (e) {
              const parentItem = e.target.closest(".sidebar__nav-item--parent");
              if (parentItem) {
                const itemId = parentItem.getAttribute("data-item-id");
                if (itemId) {
                  e.preventDefault();
                  window.toggleNavExpand(itemId);
                }
              }
            });
          });
        </script>
        <!-- Script to switch sidebars based on saved profile -->
        <script>
          (function () {
            // Function to replace sidebar content
            function replaceSidebar(profileType) {
              const container = document.getElementById(
                "dynamic-sidebar-container",
              );
              const templateId =
                profileType === "developer"
                  ? "developer-sidebar-template"
                  : "investor-sidebar-template";
              const template = document.getElementById(templateId);

              if (container && template) {
                // Clear current content
                container.innerHTML = "";
                // Clone and append new content
                const newContent = template.content.cloneNode(true);
                container.appendChild(newContent);

                // Re-initialize profile dropdown functionality
                if (typeof window.toggleProfileDropdown === "function") {
                  // The dropdown script should already be loaded
                }
              }
            }

            // Check saved profile on page load
            const savedProfile = localStorage.getItem("selectedProfile");

            // Set default profile if not set
            if (!savedProfile) {
              localStorage.setItem("selectedProfile", "investor");
            }

            // Replace sidebar with correct profile
            if (savedProfile === "developer") {
              replaceSidebar("developer");
            }
            // Investor is already loaded by default

            // Listen for profile changes
            window.addEventListener("storage", function (e) {
              if (e.key === "selectedProfile") {
                // Reload page when profile changes
                window.location.reload();
              }
            });
          })();
        </script>
      </div>
      <!-- Main Content Area -->
      <main id="developer-dashboard-main" class="marketplace-main">
