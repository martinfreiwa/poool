<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Developer Dashboard - POOOL</title>
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <!-- Alpine.js -->
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
    ></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/static/css/main.css" />
    <link rel="stylesheet" href="/static/css/marketplace.css" />
    <link rel="stylesheet" href="/static/css/wallet.css" />
    <link rel="stylesheet" href="/static/css/portfolio.css" />
    <link rel="stylesheet" href="/static/css/cart.css" />
    <link rel="stylesheet" href="/static/css/assets-table-populated.css" />
    <link rel="stylesheet" href="/static/css/bem/table.css" />
    <link rel="stylesheet" href="/static/css/property-item-card.css" />
    <link rel="stylesheet" href="/static/css/kyc-banner.css" />
    <link rel="stylesheet" href="/static/css/sidebar-navigation.css" />
    <link rel="stylesheet" href="/static/css/bem/sidebar.css" />
    <link rel="stylesheet" href="/static/css/sidebar-developer.css" />
    <link rel="stylesheet" href="/static/css/developer.css" />
    <link rel="stylesheet" href="/static/css/developer-dashboard.css" />
    <link rel="stylesheet" href="/static/css/profile-dropdown.css" />
    <link rel="stylesheet" href="/static/css/htmx-fixes.css" />
    <!-- Mobile CSS -->
    <link rel="stylesheet" href="/static/css/mobile-header.css" />
    <link rel="stylesheet" href="/static/css/mobile-burger-menu.css" />
    <link rel="stylesheet" href="/static/css/mobile-kyc-banner.css" />
    <link rel="stylesheet" href="/static/css/mobile-profile-dropdown.css" />
    <link rel="stylesheet" href="/static/css/mobile-developer-dashboard.css" />
    <!-- Custom JavaScript -->
    <script src="/static/js/htmx-init.js"></script>
    <script src="/static/js/profile-dropdown.js"></script>
    <script src="/static/js/mobile-navigation.js"></script>
    <script src="/static/js/developer-dashboard.js"></script>
    <script src="/static/js/user-data.js"></script>
    <link rel="stylesheet" href="/static/css/poool-dropdown.css" />
    <script src="/static/js/poool-dropdown.js"></script>
    <script src="/static/js/poool-dropdown-init.js"></script>
  </head>
  <body id="developer-dashboard-body">
    <!-- Mobile Header (hidden on desktop) --><!-- Mobile Header -->
    <header id="mobile-header" class="mobile-header">
      <!-- Logo --><a href="/marketplace" class="mobile-header__logo"
        ><img src="/images/Logo Pool.svg" alt="POOOL" /></a
      ><!-- Icons Container -->
      <div class="mobile-header__icons">
        <!-- Notification Button --><button
          id="mobile-notification-btn"
          class="mobile-header__icon-btn mobile-header__icon-btn--notification"
          aria-label="Notifications"
        >
          <svg
            class="mobile-header__icon"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
          >
            <path
              d="M18 8C18 6.4087 17.3679 4.88258 16.2426 3.75736C15.1174 2.63214 13.5913 2 12 2C10.4087 2 8.88258 2.63214 7.75736 3.75736C6.63214 4.88258 6 6.4087 6 8C6 15 3 17 3 17H21C21 17 18 15 18 8Z"
              stroke="#000000"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M13.73 21C13.5542 21.3031 13.3019 21.5547 12.9982 21.7295C12.6946 21.9044 12.3504 21.9965 12 21.9965C11.6496 21.9965 11.3054 21.9044 11.0018 21.7295C10.6982 21.5547 10.4458 21.3031 10.27 21"
              stroke="#000000"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path></svg
          ><!-- Badge if there are notifications --><span
            class="mobile-header__badge"
            style="display: none"
            >3</span
          ></button
        ><!-- Cart Button --><button
          id="mobile-cart-btn"
          class="mobile-header__icon-btn mobile-header__icon-btn--cart"
          onclick="window.location.href = '/cart'"
          aria-label="Shopping Cart"
        >
          <svg
            class="mobile-header__icon"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
          >
            <path
              d="M9 22C9.55228 22 10 21.5523 10 21C10 20.4477 9.55228 20 9 20C8.44772 20 8 20.4477 8 21C8 21.5523 8.44772 22 9 22Z"
              stroke="#000000"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M20 22C20.5523 22 21 21.5523 21 21C21 20.4477 20.5523 20 20 20C19.4477 20 19 20.4477 19 21C19 21.5523 19.4477 22 20 22Z"
              stroke="#000000"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M1 1H5L7.68 14.39C7.77144 14.8504 8.02191 15.264 8.38755 15.5583C8.75318 15.8526 9.2107 16.009 9.68 16H19.4C19.8693 16.009 20.3268 15.8526 20.6925 15.5583C21.0581 15.264 21.3086 14.8504 21.4 14.39L23 6H6"
              stroke="#000000"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path></svg
          ><!-- Cart Badge --><span
            class="mobile-header__badge"
            style="display: none"
            >2</span
          ></button
        ><!-- Burger Menu Button --><button
          id="mobile-burger-btn"
          class="mobile-header__icon-btn mobile-header__icon-btn--burger"
          onclick="toggleMobileMenu()"
          aria-label="Menu"
        >
          <div class="mobile-header__burger-icon">
            <span class="mobile-header__burger-line"></span>
            <span class="mobile-header__burger-line"></span>
            <span class="mobile-header__burger-line"></span>
          </div>
        </button>
      </div>
    </header>
    <!-- Mobile Menu Overlay -->
    <div
      id="mobile-menu-overlay"
      class="mobile-menu-overlay"
      onclick="closeMobileMenu()"
    ></div>
    <!-- Dynamic Mobile Burger Menu - switches based on profile -->
    <div id="mobile-burger-menu-container">
      <!-- Initial menu will be replaced by JavaScript based on profile --><!-- Mobile Burger Menu -->
      <nav id="mobile-burger-menu" class="mobile-burger-menu">
        <!-- Header -->
        <div class="mobile-burger-menu__header">
          <div class="mobile-burger-menu__header-container">
            <!-- Logo -->
