            >
              <span class="mobile-burger-menu__featured-close-icon"></span>
            </button>
            <div class="mobile-burger-menu__featured-text">
              <h4 class="mobile-burger-menu__featured-title">Community soon</h4>
              <p class="mobile-burger-menu__featured-description">
                Check out the new community feature. Connect with other
                investors soon.
              </p>
            </div>
            <div class="mobile-burger-menu__featured-actions">
              <button
                class="mobile-burger-menu__featured-button mobile-burger-menu__featured-button--dismiss"
              >
                Dismiss
              </button>
              <button
                class="mobile-burger-menu__featured-button mobile-burger-menu__featured-button--action"
              >
                What&#39;s new?
              </button>
            </div>
          </div>
          <!-- Support Chat Card - Only show for developer profile --><!-- Account Card -->
          <div
            id="mobile-account-card"
            class="mobile-burger-menu__account-card"
            onclick="toggleMobileProfileDropdown(event)"
            style="cursor: pointer"
            role="button"
            aria-label="Account menu"
            tabindex="0"
          >
            <div class="mobile-burger-menu__avatar-group">
              <div class="mobile-burger-menu__avatar">
                <img loading="lazy" src="/images/Image.webp" alt="Olivia Rhye" />
                <div class="mobile-burger-menu__avatar-online"></div>
              </div>
              <div class="mobile-burger-menu__account-text">
                <span class="mobile-burger-menu__account-name"
                  >Olivia Rhye</span
                >
                <span class="mobile-burger-menu__account-email"
                  >olivia@poool.com</span
                >
              </div>
            </div>
            <div
              id="mobile-account-menu-button"
              class="mobile-burger-menu__account-menu"
              style="pointer-events: none"
            >
              <div
                id="mobile-account-menu-button-inner"
                class="mobile-burger-menu__account-menu-button"
              >
                <svg
                  class="mobile-burger-menu__account-menu-icon"
                  width="20"
                  height="20"
                  viewBox="0 0 20 20"
                  fill="none"
                >
                  <path
                    d="M5 8L10 3L15 8"
                    stroke="#A4A7AE"
                    stroke-width="1.66667"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ></path>
                  <path
                    d="M5 12L10 17L15 12"
                    stroke="#A4A7AE"
                    stroke-width="1.66667"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ></path>
                </svg>
              </div>
            </div>
          </div>
          <!-- Mobile Profile Dropdown -->
          <div
            id="mobile-profile-dropdown-menu"
            class="mobile-profile-dropdown-menu"
          >
            <!-- Menu items wrapper -->
            <div
              id="mobile-profile-menu-wrapper"
              class="mobile-profile-menu-wrapper"
            >
              <!-- Top menu items -->
              <div
                id="mobile-profile-menu-items-top"
                class="mobile-profile-menu-items"
              >
                <!-- Documentation -->
                <div
                  id="mobile-menu-item-documentation"
                  class="mobile-profile-menu-item"
                >
                  <div class="mobile-profile-menu-content">
                    <div class="mobile-profile-icon-text">
                      <svg
                        class="mobile-profile-menu-icon"
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="none"
                      >
                        <path
                          d="M4 4V16H16V4H4Z"
                          stroke="#717680"
                          stroke-width="1.67"
                        ></path>
                        <path
                          d="M8 8H12M8 12H12"
                          stroke="#717680"
                          stroke-width="1.67"
                          stroke-linecap="round"
                        ></path>
                      </svg>
                      <span class="mobile-profile-menu-text"
                        >Documentation</span
                      >
                    </div>
                  </div>
                </div>
              </div>
              <!-- Switch account section -->
              <div
                id="mobile-profile-switch-section"
                class="mobile-profile-switch-section"
              >
                <div class="mobile-profile-switch-header">
                  <span class="mobile-profile-switch-title"
                    >Switch account</span
                  >
                </div>
                <!-- Current account (selected) -->
                <div
                  id="mobile-menu-item-current-account"
                  class="mobile-profile-menu-item account-item selected mobile-profile-switcher"
                  data-profile-id="olivia-investor"
                  data-account-type="Investor Profile"
                  style="cursor: pointer"
                >
                  <div class="mobile-profile-account-content">
                    <div class="mobile-profile-avatar-group">
                      <div class="mobile-profile-avatar">
                        <img loading="lazy" src="/images/Image.webp" alt="Olivia Rhye" />
                        <div class="mobile-profile-avatar-border"></div>
                        <div class="mobile-profile-online-indicator"></div>
                      </div>
                      <div class="mobile-profile-text-wrapper">
                        <span class="mobile-profile-account-name"
                          >Olivia Rhye</span
                        >
                        <span class="mobile-profile-account-type"
                          >Investor Profile</span
                        >
                      </div>
                    </div>
                    <div class="mobile-profile-checkbox selected">
                      <div class="mobile-profile-checkbox-check"></div>
                    </div>
                  </div>
                </div>
                <!-- Other accounts -->
                <div
                  id="mobile-menu-item-account-olivia-developer"
                  class="mobile-profile-menu-item account-item mobile-profile-switcher"
                  data-profile-id="olivia-developer"
                  data-account-type="Developer profile"
                  style="cursor: pointer"
                >
                  <div class="mobile-profile-account-content">
                    <div class="mobile-profile-avatar-group">
                      <div class="mobile-profile-avatar">
                        <img loading="lazy"
                          src="/images/Featured icon.webp"
                          alt="Olivia Rhye"
                        />
                        <div class="mobile-profile-avatar-border"></div>
                        <div class="mobile-profile-online-indicator"></div>
                      </div>
                      <div class="mobile-profile-text-wrapper">
                        <span class="mobile-profile-account-name"
                          >Olivia Rhye</span
                        >
                        <span class="mobile-profile-account-type"
                          >Developer profile</span
                        >
                      </div>
                    </div>
                    <div class="mobile-profile-checkbox">
                      <div class="mobile-profile-checkbox-check"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <!-- Footer items -->
            <div
              id="mobile-profile-footer-items"
              class="mobile-profile-footer-items"
            >
              <!-- Sign out -->
              <div
                id="mobile-menu-item-sign-out"
                class="mobile-profile-menu-item"
              >
                <div class="mobile-profile-menu-content">
                  <div class="mobile-profile-icon-text">
                    <svg
                      class="mobile-profile-menu-icon"
                      width="20"
                      height="20"
                      viewBox="0 0 20 20"
                      fill="none"
                    >
                      <path
                        d="M14 15L19 10L14 5"
                        stroke="#717680"
                        stroke-width="1.67"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                      <path
                        d="M19 10H7M7 19H3C2.44772 19 2 18.5523 2 18V2C2 1.44772 2.44772 1 3 1H7"
                        stroke="#717680"
                        stroke-width="1.67"
                        stroke-linecap="round"
                      ></path>
                    </svg>
                    <span class="mobile-profile-menu-text">Sign out</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Mobile Profile Switching JavaScript -->
          <script>
            // Profile switching functionality - consistent with desktop
            window.switchToProfile = function (profileId, accountType) {
              // Close the mobile dropdown first
              if (window.closeMobileProfileDropdown) {
                window.closeMobileProfileDropdown();
              }

              // Close the burger menu
              if (window.closeMobileMenu) {
                window.closeMobileMenu();
              }

              // Determine profile type and save to localStorage (consistent with desktop)
              let profileType = "investor"; // default
              if (accountType === "Developer profile") {
                profileType = "developer";
              } else if (accountType === "Investor Profile") {
                profileType = "investor";
              }

              localStorage.setItem("selectedProfile", profileType);
              localStorage.setItem("selectedAccountId", profileId);

              // Switch to appropriate dashboard
              if (profileType === "developer") {
                window.location.href = "/developer/dashboard";
              } else {
                window.location.href = "/marketplace";
              }
            };

            // Load saved profile from localStorage - mirrors desktop behavior
            window.loadSavedMobileProfile = function () {
              const savedProfile = localStorage.getItem("selectedProfile");
              const savedAccountId = localStorage.getItem("selectedAccountId");

              if (savedProfile && savedAccountId) {
                // Update dropdown selection state
                const allAccountItems = document.querySelectorAll(
                  ".mobile-profile-menu-item.account-item",
                );
                allAccountItems.forEach(function (item) {
                  const checkbox = item.querySelector(
                    ".mobile-profile-checkbox",
                  );
                  if (
                    item.id.includes(savedAccountId) ||
                    (savedAccountId === "olivia-investor" &&
                      item.id === "mobile-menu-item-current-account")
                  ) {
                    // This is the selected account
                    item.classList.add("selected");
                    if (checkbox) checkbox.classList.add("selected");
                  } else {
                    // This is not the selected account
                    item.classList.remove("selected");
                    if (checkbox) checkbox.classList.remove("selected");
                  }
                });

                // Update mobile burger menu account display based on saved selection
                const selectedItem = document.querySelector(
                  savedAccountId === "olivia-investor"
                    ? "#mobile-menu-item-current-account"
                    : "#mobile-menu-item-account-" + savedAccountId,
                );

                if (selectedItem) {
                  const avatar = selectedItem.querySelector(
                    ".mobile-profile-avatar img",
                  );
                  const name = selectedItem.querySelector(
                    ".mobile-profile-account-name",
                  );
                  const type = selectedItem.querySelector(
                    ".mobile-profile-account-type",
                  );

                  const mobileAvatar = document.querySelector(
                    ".mobile-burger-menu__avatar img",
                  );
                  const mobileName = document.querySelector(
                    ".mobile-burger-menu__account-name",
                  );
                  const mobileEmail = document.querySelector(
                    ".mobile-burger-menu__account-email",
                  );

                  if (avatar && mobileAvatar) {
                    mobileAvatar.src = avatar.src;
                    mobileAvatar.alt = avatar.alt;
                  }

                  if (name && mobileName) {
                    mobileName.textContent = name.textContent;
                  }

                  if (type && mobileEmail) {
                    mobileEmail.textContent = type.textContent;
                  }
                }
              }
            };

            // Initialize profile switchers - bypasses global event capture
            window.initializeProfileSwitchers = function () {
              const profileSwitchers = document.querySelectorAll(
                ".mobile-profile-switcher",
              );

              profileSwitchers.forEach(function (switcher, index) {
                const profileId = switcher.getAttribute("data-profile-id");
                const accountType = switcher.getAttribute("data-account-type");

                // Remove any existing listeners
                switcher.removeEventListener(
                  "click",
                  switcher._profileSwitchHandler,
                );

                // Create and store the handler
                switcher._profileSwitchHandler = function (e) {
                  e.preventDefault();
                  e.stopPropagation();
                  e.stopImmediatePropagation();
                  window.switchToProfile(profileId, accountType);
                };

                // Add the event listener
                switcher.addEventListener(
                  "click",
                  switcher._profileSwitchHandler,
                  true,
                );
              });
            };

            // Initialize when DOM is ready and also when mobile menu is opened
            function initializeAll() {
              window.loadSavedMobileProfile();
              window.initializeProfileSwitchers();
            }

            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", initializeAll);
            } else {
              initializeAll();
            }

            // Mobile profile dropdown toggle functionality
            window.toggleMobileProfileDropdown = function (event) {
              if (event) {
                event.preventDefault();
                event.stopPropagation();
                event.stopImmediatePropagation();
              }

              const dropdown = document.getElementById(
                "mobile-profile-dropdown-menu",
              );
              const button = document.getElementById(
                "mobile-account-menu-button-inner",
              );

              if (!dropdown) {
                // Try to find it with different selectors
                const allDropdowns = document.querySelectorAll(
                  '[id*="profile-dropdown"], [class*="profile-dropdown"]',
                );
                allDropdowns.forEach((el, i) =>
                  console.log(`  ${i}:`, el.id, el.className),
                );
                return;
              }

              // Toggle dropdown visibility using active class
              const isCurrentlyActive = dropdown.classList.contains("active");

              if (!isCurrentlyActive) {
                dropdown.classList.add("active");
                if (button) button.classList.add("active");

                // Re-initialize profile switchers for the newly visible dropdown
                setTimeout(() => {
                  window.initializeProfileSwitchers();
                }, 50);

                // Add click outside listener
                setTimeout(() => {
                  document.addEventListener(
                    "click",
                    window.closeMobileDropdownOnClickOutside,
                  );
                }, 100);
              } else {
                dropdown.classList.remove("active");
                if (button) button.classList.remove("active");

                // Remove click outside listener
                document.removeEventListener(
                  "click",
                  window.closeMobileDropdownOnClickOutside,
                );
              }
            };

            window.closeMobileProfileDropdown = function () {
              const dropdown = document.getElementById(
                "mobile-profile-dropdown-menu",
              );
              const button = document.getElementById(
                "mobile-account-menu-button-inner",
              );

              if (dropdown) dropdown.classList.remove("active");
              if (button) button.classList.remove("active");

              // Remove click outside listener
              document.removeEventListener(
                "click",
                window.closeMobileDropdownOnClickOutside,
              );
            };

            window.closeMobileDropdownOnClickOutside = function (event) {
              const dropdown = document.getElementById(
                "mobile-profile-dropdown-menu",
              );
              const accountCard = document.getElementById(
                "mobile-account-card",
              );

              if (
                accountCard &&
                !accountCard.contains(event.target) &&
                dropdown &&
                !dropdown.contains(event.target)
              ) {
                window.closeMobileProfileDropdown();
              }
            };

            // Mobile Marketplace Dropdown Toggle
            window.toggleMobileMarketplaceDropdown = function (event) {
              // Prevent default behavior and event propagation
              if (event) {
                event.preventDefault();
                event.stopPropagation();
                event.stopImmediatePropagation();
              }

              const chevron = document.querySelector(
                ".mobile-burger-menu__nav-chevron",
              );
              const childrenContainer = document.getElementById(
                "mobile-nav-children-marketplace",
              );

              if (!chevron || !childrenContainer) {
                return;
              }

              // Toggle expanded state
              const isExpanded = chevron.classList.contains(
                "mobile-burger-menu__nav-chevron--expanded",
              );

              if (isExpanded) {
                // Collapse
                chevron.classList.remove(
                  "mobile-burger-menu__nav-chevron--expanded",
                );
                childrenContainer.classList.add(
                  "mobile-burger-menu__nav-children--collapsed",
                );
              } else {
                // Expand
                chevron.classList.add(
                  "mobile-burger-menu__nav-chevron--expanded",
                );
                childrenContainer.classList.remove(
                  "mobile-burger-menu__nav-children--collapsed",
                );
              }
            };
          </script>
        </div>
      </nav>
    </div>
