            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </button>
    </div>
    <div id="developer-dashboard-page" class="marketplace-page">
      <!-- Sidebar Navigation -->
      <div id="developer-dashboard-sidebar" class="marketplace-sidebar">
        <!-- Container that will show only one sidebar at a time -->
        <div id="dynamic-sidebar-container">
          <!-- Initial sidebar will be replaced by JavaScript -->
          <aside
            id="sidebar-navigation"
            class="sidebar"
            data-profile="investor"
          >
            <div id="sidebar-content" class="sidebar__content">
              <!-- Navigation Section -->
              <div id="sidebar-navigation-section" class="sidebar__nav-section">
                <!-- Header Section -->
                <div id="sidebar-header" class="sidebar__header">
                  <!-- Logo --><a
                    id="sidebar-logo"
                    href="/"
