                      <div
                        id="developer-assets-cell-conversion-6"
                        class="table__cell table__cell--conversion"
                        else
                        style="width: 156px"
                        else
                      >
                        <span class="table__cell-text-value">7.7%</span>
                      </div>
                      <div
                        id="developer-assets-cell-funding-6"
                        class="table__cell table__cell--funding"
                        else
                        style="width: 216px"
                        else
                      >
                        <div class="table__progress-group">
                          <span class="table__progress-text">83% funded</span>
                          <div class="table__progress-bar">
                            <div
                              class="table__progress-fill"
                              style="width: 83%"
                            ></div>
                          </div>
                        </div>
                      </div>
                      <div
                        id="developer-assets-cell-actions-6"
                        class="table__cell table__cell--actions"
                        style="width: 160px; text-align: center"
                        else
                        style="width: 160px"
                        else
                        style="text-align: center"
                      >
                        <button class="table__action-btn">
                          <span>View details</span>
                          <svg
                            width="20"
                            height="20"
                            viewBox="0 0 20 20"
                            fill="none"
                          >
                            <path
                              d="M7.5 5L12.5 10L7.5 15"
                              stroke="#000000"
                              stroke-width="1.66667"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                  <div id="developer-assets-show-all" class="table__show-all">
                    <button
                      id="developer-assets-show-all-btn"
                      class="table__show-all-btn"
                    >
                      <span>Show All</span>
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="none"
                      >
                        <path
                          d="M7.5 5L12.5 10L7.5 15"
                          stroke="#0000FF"
                          stroke-width="1.66667"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        ></path>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
