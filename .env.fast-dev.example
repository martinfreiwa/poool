# POOOL fast-dev profile
# Copy to .env.fast-dev or backend/.env for quick local cargo runs.
# This profile is intentionally convenient, not production-like.

APP_ENV=development
POOOL_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8888
BASE_URL=http://localhost:8888

DATABASE_URL=postgres://martin@localhost/poool
COMMUNITY_DATABASE_URL=postgres://martin@localhost/poool_community

# Optional in fast-dev. If absent, rate limits are in-memory and marketplace matching workers are disabled.
REDIS_URL=

# Required for local health to be fully ok and for 2FA/session-sensitive flows.
SESSION_SECRET=replace-with-local-random-secret
TOTP_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional sandbox integrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
GCS_BUCKET_NAME=
SANITY_PROJECT_ID=3y7eud93
SANITY_DATASET=production
SANITY_API_VERSION=2026-04-24
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Keep disabled for fast-dev unless explicitly testing chain workers.
CHAIN_SETTLEMENT_ENABLED=false
CHAIN_NETWORK=polygon_amoy
CHAIN_ID=80002
CHAIN_RPC_URL=
CHAIN_CONTRACT_ADDRESS=
CHAIN_IDENTITY_REGISTRY_ADDRESS=
CHAIN_SETTLEMENT_ADDRESS=
CHAIN_SETTLEMENT_PRIVATE_KEY=
CHAIN_KMS_KEY=
