        </a>
      </div>
      <!-- Footer -->
      <div class="mobile-burger-menu__footer">
        <!-- Featured Card - Only show for investor profile -->
        <div class="mobile-burger-menu__featured-card">
          <button class="mobile-burger-menu__featured-close" aria-label="Close">
            <span class="mobile-burger-menu__featured-close-icon"></span>
          </button>
          <div class="mobile-burger-menu__featured-text">
            <h4 class="mobile-burger-menu__featured-title">Community soon</h4>
            <p class="mobile-burger-menu__featured-description">
              Check out the new community feature. Connect with other
              investors soon.
            </p>
          </div>
          <div class="mobile-burger-menu__featured-actions">
            <button class="mobile-burger-menu__featured-button mobile-burger-menu__featured-button--dismiss">
