                      <div class="profile-menu-content">
                        <div class="profile-icon-text">
                          <svg class="profile-menu-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
                            <path d="M14 15L19 10L14 5" stroke="#717680" stroke-width="1.67" stroke-linecap="round"
                              stroke-linejoin="round"></path>
                            <path d="M19 10H7M7 19H3C2.44772 19 2 18.5523 2 18V2C2 1.44772 2.44772 1 3 1H7"
                              stroke="#717680" stroke-width="1.67" stroke-linecap="round"></path>
