          <!-- Profile Dropdown JavaScript -->
          <script>
            // Profile Dropdown Functions - Global scope
            window.toggleProfileDropdown = function () {
              const dropdown = document.getElementById(
                "profile-dropdown-menu",
              );
              const button = document.getElementById(
                "account-menu-button-inner",
              );

              if (!dropdown) {
                return;
              }

              // SAFARI FIX: Move to body and restore proper styling

              // Move to body to escape stacking context
              if (dropdown.parentNode !== document.body) {
                document.body.appendChild(dropdown);
              }

              // Apply proper dropdown styles (restore original design)
              dropdown.style.display = "flex";
              dropdown.style.position = "fixed";
              dropdown.style.left = "248px"; // Original position
              dropdown.style.bottom = "20px"; // Original position
              dropdown.style.width = "264px"; // Original width
              dropdown.style.height = "auto"; // Original height
              dropdown.style.background = ""; // Clear test background
              dropdown.style.border = ""; // Clear test border
              dropdown.style.zIndex = "99999"; // High z-index for Safari

              // Restore original CSS classes
              dropdown.className = "profile-dropdown-menu";

              if (button) button.classList.add("active");

              // Add click outside listener
              setTimeout(() => {
                document.addEventListener(
                  "click",
                  window.closeDropdownOnClickOutside,
                );
              }, 100);
            };

            window.closeProfileDropdown = function () {
              const dropdown = document.getElementById(
                "profile-dropdown-menu",
              );
              const button = document.getElementById(
                "account-menu-button-inner",
              );

              if (dropdown) dropdown.style.display = "none";
              if (button) button.classList.remove("active");

              // Remove click outside listener
              document.removeEventListener(
                "click",
                window.closeDropdownOnClickOutside,
              );
            };

            window.closeDropdownOnClickOutside = function (event) {
              const dropdown = document.getElementById(
                "profile-dropdown-menu",
              );
              const accountCard = document.getElementById("nav-account-card");

              if (
                accountCard &&
                !accountCard.contains(event.target) &&
                dropdown &&
                !dropdown.contains(event.target)
              ) {
                window.closeProfileDropdown();
              }
            };

            // Profile dropdown functionality is handled by profile-dropdown.js
          </script>
