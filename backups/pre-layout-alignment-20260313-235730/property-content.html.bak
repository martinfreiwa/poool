        </div>
        <!-- Support Chat Card - Only show for developer profile --><!-- Account Card -->
        <div id="mobile-account-card" class="mobile-burger-menu__account-card"
          onclick="toggleMobileProfileDropdown(event)" style="cursor: pointer" role="button" aria-label="Account menu"
          tabindex="0">
