              <div class="mobile-burger-menu__avatar-online"></div>
            </div>
            <div class="mobile-burger-menu__account-text">
              <span class="mobile-burger-menu__account-name"></span>
              <span class="mobile-burger-menu__account-email"></span>
            </div>
          </div>
          <div id="mobile-account-menu-button" class="mobile-burger-menu__account-menu" style="pointer-events: none">
            <div id="mobile-account-menu-button-inner" class="mobile-burger-menu__account-menu-button">
              <svg class="mobile-burger-menu__account-menu-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M5 8L10 3L15 8" stroke="#A4A7AE" stroke-width="1.66667" stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path d="M5 12L10 17L15 12" stroke="#A4A7AE" stroke-width="1.66667" stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mobile Profile Dropdown -->
        <div id="mobile-profile-dropdown-menu" class="mobile-profile-dropdown-menu">
          <!-- Menu items wrapper -->
          <div id="mobile-profile-menu-wrapper" class="mobile-profile-menu-wrapper">
            <!-- Top menu items -->
            <div id="mobile-profile-menu-items-top" class="mobile-profile-menu-items">
              <!-- Documentation -->
              <div id="mobile-menu-item-documentation" class="mobile-profile-menu-item">
                <div class="mobile-profile-menu-content">
                  <div class="mobile-profile-icon-text">
                    <svg class="mobile-profile-menu-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <path d="M4 4V16H16V4H4Z" stroke="#717680" stroke-width="1.67"></path>
                      <path d="M8 8H12M8 12H12" stroke="#717680" stroke-width="1.67" stroke-linecap="round"></path>
                    </svg>
                    <span class="mobile-profile-menu-text">Documentation</span>
                  </div>
                </div>
              </div>
            </div>
            <!-- Switch account section -->
            <div id="mobile-profile-switch-section" class="mobile-profile-switch-section">
              <div class="mobile-profile-switch-header">
                <span class="mobile-profile-switch-title">Switch account</span>
              </div>
              <!-- Current account (selected) -->
              <div id="mobile-menu-item-current-account"
                class="mobile-profile-menu-item account-item selected mobile-profile-switcher"
                data-profile-id="olivia-investor" data-account-type="Investor Profile" style="cursor: pointer">
                <div class="mobile-profile-account-content">
                  <div class="mobile-profile-avatar-group">
                    <div class="mobile-profile-avatar">
                      <img loading="lazy" src="/images/Image.webp" alt="" />
                      <div class="mobile-profile-avatar-border"></div>
                      <div class="mobile-profile-online-indicator"></div>
                    </div>
                    <div class="mobile-profile-text-wrapper">
                      <span class="mobile-profile-account-name"></span>
                      <span class="mobile-profile-account-type">Investor Profile</span>
                    </div>
                  </div>
                  <div class="mobile-profile-checkbox selected">
                    <div class="mobile-profile-checkbox-check"></div>
                  </div>
                </div>
              </div>
              <!-- Other accounts -->
              <div id="mobile-menu-item-account-olivia-developer"
                class="mobile-profile-menu-item account-item mobile-profile-switcher" data-profile-id="olivia-developer"
                data-account-type="Developer profile" style="cursor: pointer">
                <div class="mobile-profile-account-content">
                  <div class="mobile-profile-avatar-group">
                    <div class="mobile-profile-avatar">
                      <img loading="lazy" src="/images/Featured icon.webp" alt="" />
                      <div class="mobile-profile-avatar-border"></div>
                      <div class="mobile-profile-online-indicator"></div>
                    </div>
                    <div class="mobile-profile-text-wrapper">
                      <span class="mobile-profile-account-name"></span>
                      <span class="mobile-profile-account-type">Developer profile</span>
                    </div>
                  </div>
                  <div class="mobile-profile-checkbox">
