{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, title, tokens_total, tokens_available, min_funding_tokens\n        FROM assets\n        WHERE funding_status IN ('funding_open', 'funding_in_progress')\n          AND funding_end_at < NOW()\n          AND (tokens_total - tokens_available) < min_funding_tokens\n        ",
