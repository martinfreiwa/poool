  "query": "\n                SELECT w.id, w.user_id, w.wallet_type, w.currency, w.balance_cents, u.email\n                FROM wallets w\n                JOIN users u ON u.id = w.user_id\n                WHERE w.balance_cents < 0\n                LIMIT 50\n                ",
