{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            t.id, \n            t.executed_at, \n            a.title as asset_name,\n            t.buyer_user_id,\n            t.seller_user_id,\n            t.price_cents,\n            t.quantity,\n            t.fee_cents\n        FROM trade_history t\n        JOIN assets a ON t.asset_id = a.id\n        WHERE t.buyer_user_id = $1 OR t.seller_user_id = $1\n        ORDER BY t.executed_at DESC\n        LIMIT 100\n        ",
