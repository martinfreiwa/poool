{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            a.id,\n            a.slug,\n            a.title,\n            a.asset_type,\n            COALESCE(a.location_city, '') as \"location_city!\",\n            COALESCE(a.location_country, '') as \"location_country!\",\n            a.token_price_cents,\n            a.tokens_total,\n            a.annual_yield_bps,\n            a.description,\n            a.total_value_cents,\n            a.land_size_sqm,\n            a.bedrooms,\n            a.funding_status,\n            a.location_description,\n            a.occupancy_rate_bps,\n            a.lease_type,\n            a.property_type,\n            ARRAY(\n                SELECT image_url \n                FROM asset_images \n                WHERE asset_id = a.id \n                ORDER BY is_cover DESC, created_at ASC\n            ) AS \"image_urls!\"\n        FROM assets a\n        WHERE a.published = true\n          AND a.asset_type != 'commodity'\n          AND a.funding_status IN ('funded', 'funding_in_progress', 'funding_open')\n        ",
