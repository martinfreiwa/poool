  "query": "\n            SELECT u.id as \"id!\", u.email, up.display_name, up.first_name, up.last_name, u.avatar_url \n            FROM users u\n            LEFT JOIN user_profiles up ON u.id = up.user_id\n            WHERE u.id = ANY($1)\n            ",
