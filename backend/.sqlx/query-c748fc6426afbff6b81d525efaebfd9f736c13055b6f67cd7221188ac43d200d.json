{
  "db_name": "PostgreSQL",
  "query": "SELECT id, name, scope, asset_id, taker_fee_bps, maker_fee_bps,\n                  starts_at, ends_at, is_active, created_by, created_at\n           FROM fee_promotions\n           WHERE is_active = true\n             AND starts_at <= NOW()\n             AND ends_at > NOW()\n             AND (scope = 'global' OR (scope = 'asset' AND asset_id = $1))\n           ORDER BY\n             CASE WHEN scope = 'asset' THEN 0 ELSE 1 END,\n             starts_at DESC\n           LIMIT 1",
