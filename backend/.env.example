# POOOL Backend – Local Development Environment

# ─── Database ────────────────────────────────────────────────────
# Adjust to your local Postgres credentials!
DATABASE_URL=postgres://martin@localhost/poool

# Maximum DB connections per instance (default: 20).
# Keep this below your Postgres max_connections / number_of_instances.
DATABASE_MAX_CONNECTIONS=20

# ─── Server Bindings ─────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8888

# ─── Environment ─────────────────────────────────────────────────
# Controls cookie Secure flag and Sentry environment.
# Values: development | staging | production
# IMPORTANT: Cookies default to Secure=true unless this is set to "development".
POOOL_ENV=development

# Also used by Sentry for environment tagging.
APP_ENV=development

# ─── Logging ─────────────────────────────────────────────────────
RUST_LOG=info

# ─── Base URL ────────────────────────────────────────────────────
# Used for OAuth callbacks, email links, etc.
BASE_URL=http://localhost:8888

# ─── OAuth2 ──────────────────────────────────────────────────────

# Google: https://console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0 Client-IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook: https://developers.facebook.com -> My Apps -> Set up Facebook Login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── KYC Provider: Didit.me ──────────────────────────────────────
# Get keys from: https://business.didit.me -> Application -> API & Webhooks
# If not set, the platform falls back to manual KYC review.
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=

# ─── File Storage (Google Cloud Storage) ─────────────────────────
# Bucket name for user uploads (avatars, KYC docs, property images).
# If not set, upload endpoints return 503.
GCS_BUCKET_NAME=

# On Cloud Run, the Cloud SQL Auth Proxy socket is auto-detected.
# Override with this if needed:
# CLOUD_SQL_SOCKET_PATH=/cloudsql/your-project:region:instance

# ─── Caching (Redis) ─────────────────────────────────────────────
# Optional. Used for session caching and query result caching.
REDIS_URL=

# ─── Two-Factor Authentication (TOTP) ───────────────────────────
# Required for 2FA setup. 32-byte hex key used to encrypt TOTP secrets at rest.
# Generate: openssl rand -hex 32
TOTP_SECRET_ENCRYPTION_KEY=

# ─── Error Monitoring (Sentry) ───────────────────────────────────
# Optional. DSN from https://sentry.io/settings/projects/
SENTRY_DSN=

# ─── Payments (Stripe) ──────────────────────────────────────────
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
