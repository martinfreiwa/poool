# ──────────────────────────────────────────────────────────────
#  POOOL Smart Contracts — Environment Variables
# ──────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit .env to git (it's already in .gitignore)
# ──────────────────────────────────────────────────────────────

# === Deployer Wallet ===
# Private key of the wallet that deploys and administers the contract.
# GENERATE A NEW WALLET FOR TESTNET — never use your mainnet key on testnet!
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# === Admin Address ===
# The address that will receive all admin roles (DEFAULT_ADMIN, MINTER, PAUSER, SETTLEMENT).
# This can be the same as the deployer or a separate multisig.
ADMIN_ADDRESS=0x_YOUR_ADMIN_ADDRESS_HERE

# === Settlement Wallet ===
# The backend service wallet that calls settleBatch() for end-of-day settlement.
# Used by PostDeploySetup.s.sol
SETTLEMENT_WALLET=0x_YOUR_SETTLEMENT_WALLET_HERE

# === Contract Address ===
# Set this AFTER deployment — used by PostDeploySetup.s.sol
CONTRACT_ADDRESS=0x_DEPLOYED_CONTRACT_ADDRESS

# === Base URI ===
# Default metadata URI for tokens without custom URIs
BASE_URI=https://api.poool.app/metadata/

# === RPC Endpoints ===
# Polygon Amoy Testnet (get free RPC from https://www.alchemy.com or https://rpc.ankr.com/polygon_amoy)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Polygon Mainnet (get from Alchemy, Infura, or QuickNode)
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com

# === PolygonScan API Key ===
# For contract verification. Get from https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
