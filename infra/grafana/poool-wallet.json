{
  "title": "POOOL Wallet — Deposits, Withdrawals, Compliance",
  "description": "Production wallet KPIs sourced from the Rust backend's /metrics endpoint. Pair with infra/prometheus/alerts.yml for alerting.",
  "tags": ["poool", "wallet", "payments", "compliance"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Deposits in last 24h",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(wallet_deposits_total{outcome=\"initiated\"}[24h]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 2,
      "title": "Deposit volume (cents) in last 24h",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(wallet_amount_cents_total{kind=\"deposit\",outcome=\"initiated\"}[24h])) / 100",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 0 } }
    },
    {
      "id": 3,
      "title": "Withdrawals requested 24h",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(wallet_withdrawals_total{outcome=\"requested\"}[24h]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 4,
      "title": "Open compliance alerts (critical+high)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(compliance_alerts_open{severity=~\"high|critical\"})",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Deposit lifecycle — rate over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(wallet_deposits_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table" } },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 11,
      "title": "Withdrawal lifecycle — rate over time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(wallet_withdrawals_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table" } },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 20,
      "title": "Reconciliation findings (current)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "wallet_reconciliation_findings",
          "legendFormat": "{{finding}}",
          "refId": "A"
        }
      ],
      "options": { "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 21,
      "title": "Compliance alerts open by severity",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "compliance_alerts_open",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "options": { "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 30,
      "title": "Sanctions re-screening outcomes (rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(compliance_screening_runs_total[1h]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 31,
      "title": "Backend HTTP error rate (5xx %)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.001) * 100",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    }
  ]
}
