{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["start_local.sh"],
      "port": 8888
    },
    {
      "name": "backend-dev",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && PORT=8889 SERVER_PORT=8889 cargo run"],
      "port": 8889
    },
    {
      "name": "backend-4000",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "PORT=4000 SERVER_PORT=4000 bash start_local.sh"],
      "port": 4000
    },
    {
      "name": "badges-showcase",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "7777", "--directory", "frontend/platform"],
      "port": 7777
    }
  ]
}
